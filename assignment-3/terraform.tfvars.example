# Basic
project_name   = "ci-cd-dashboard"
environment    = "dev"
aws_region     = "us-east-1"

# Networking
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
public_subnet_az    = "us-east-1a"

# Security group toggles and CIDRs
enable_http      = true
allow_http_cidrs = ["0.0.0.0/0"]
enable_https     = false
allow_https_cidrs = ["0.0.0.0/0"]
enable_ssh       = true
allow_ssh_cidrs  = ["YOUR_PUBLIC_IP/32"]

# EC2 settings
instance_type   = "t3.small"
volume_size_gb  = 20
ami_id          = "" # leave empty to auto-select Amazon Linux 2023
key_pair_name   = "your-keypair-name" # leave empty to skip; use SSM if enabled
enable_ssm      = true

# App deployment settings
app_repo_url      = "https://github.com/your/repo.git"
app_repo_branch   = "main"
app_setup_type    = "compose" # or "manual"
compose_file_path = "docker-compose.yml"
working_dir       = "."
backend_port      = 3000
frontend_port     = 80

# Optionally run additional commands at the end of user data
extra_user_commands = ""


